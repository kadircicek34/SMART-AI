# Public gateway auth keys (comma-separated)
APP_API_KEYS=dev-admin-key

# Tenant OpenRouter keys are stored encrypted via /v1/keys/openrouter.
# Optional global fallback key:
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-chat-v3.1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAX_RETRIES=2
OPENROUTER_RETRY_BASE_DELAY_MS=400
OPENROUTER_RETRY_MAX_DELAY_MS=4000

# Security
MASTER_KEY_BASE64=
SECURITY_AUDIT_MAX_EVENTS_PER_TENANT=300

# Runtime
PORT=8080
REQUEST_TIMEOUT_MS=45000
RATE_LIMIT_PER_MINUTE=60
UI_SESSION_TTL_SECONDS=1800
UI_SESSION_MAX_AUTH_FAILURES=5
UI_SESSION_AUTH_BLOCK_SECONDS=120
UI_ALLOWED_ORIGINS=
MAX_STEPS=6
MAX_TOOL_CALLS=6
MAX_RUNTIME_MS=60000

# Orchestrator tuning
ORCHESTRATOR_MAX_TOOL_PASSES=4
ORCHESTRATOR_MAX_REPEATED_TOOL_PASSES=2
VERIFIER_MIN_CITATIONS=2
VERIFIER_MIN_SOURCE_DOMAINS=2
RESEARCH_MAX_QUERIES=3
RESEARCH_MAX_CONCURRENT_UNITS=2

# Optional: per-tenant allowed tools JSON map
# TENANT_TOOL_POLICIES_JSON={"tenant-a":["web_search","wikipedia","rag_search"]}
TENANT_TOOL_POLICIES_JSON=

# Optional external tool providers
EXA_API_KEY=
FINANCIAL_DATASETS_API_KEY=
ALPHA_VANTAGE_API_KEY=
BRAVE_API_KEY=
BRAVE_API_BASE_URL=https://api.search.brave.com/res/v1/web/search

# Optional RAG config
RAG_STORE_FILE=
RAG_DEFAULT_CHUNK_SIZE=1200
RAG_DEFAULT_CHUNK_OVERLAP=180

# Optional Memory config
MEMORY_STORE_FILE=
MEMORY_DEFAULT_CATEGORY=note
MEMORY_MAX_ITEMS_PER_TENANT=2500
MEMORY_AUTO_CAPTURE_USER_MESSAGES=true
MEMORY_HOTNESS_HALF_LIFE_DAYS=7

# Optional QMD local-search integration (use installed VPS qmd binary)
QMD_ENABLED=true
QMD_COMMAND=qmd
QMD_TIMEOUT_MS=15000
QMD_COLLECTION_NAME=SMART-AI
QMD_COLLECTION_PATH=
QMD_COLLECTION_AUTO_ADD=true
QMD_MAX_RESULTS=6
QMD_MAX_SNIPPET_CHARS=260

# Optional Turkish domain MCP integrations (via mcporter)
MCPORTER_COMMAND=mcporter
MCPORTER_TIMEOUT_MS=45000
MCP_MAX_RESULTS=6
MEVZUAT_MCP_URL=https://mevzuat.surucu.dev/mcp
BORSA_MCP_URL=https://borsamcp.fastmcp.app/mcp
YARGI_MCP_URL=https://yargimcp.fastmcp.app/mcp
YARGI_MCP_FALLBACK_ENABLED=true

# Optional MCP health persistence
MCP_HEALTH_PERSIST_ENABLED=true
MCP_HEALTH_PERSIST_MODE=file
MCP_HEALTH_STORE_FILE=
MCP_HEALTH_PERSIST_HTTP_URL=
MCP_HEALTH_PERSIST_HTTP_TOKEN=
MCP_HEALTH_PERSIST_HTTP_TIMEOUT_MS=2500
MCP_HEALTH_PERSIST_DEBOUNCE_MS=750
