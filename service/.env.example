# Public gateway auth keys (comma-separated). Legacy keys receive full tenant:admin access.
APP_API_KEYS=dev-admin-key

# Optional scoped key registry (JSON array). When present, use for read/operate/admin split.
# APP_API_KEY_DEFINITIONS=[{"name":"dashboard-ro","key":"dashboard-read-key","scopes":["tenant:read"]},{"name":"tenant-ops","key":"tenant-ops-key","scopes":["tenant:read","tenant:operate"]},{"name":"tenant-admin","key":"tenant-admin-key","scopes":["tenant:admin"]}]
APP_API_KEY_DEFINITIONS=

# Tenant OpenRouter keys are stored encrypted via /v1/keys/openrouter.
# Optional global fallback key:
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-chat-v3.1
OPENROUTER_ALLOWED_MODELS=deepseek/deepseek-chat-v3.1
OPENROUTER_MAX_TENANT_ALLOWED_MODELS=12
OPENROUTER_MODEL_ID_MAX_LENGTH=120
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAX_RETRIES=2
OPENROUTER_RETRY_BASE_DELAY_MS=400
OPENROUTER_RETRY_MAX_DELAY_MS=4000

# Security
MASTER_KEY_BASE64=
SECURITY_AUDIT_MAX_EVENTS_PER_TENANT=300
SECURITY_AUDIT_PERSIST_DEBOUNCE_MS=250
SECURITY_AUTH_HEADER_MAX_LENGTH=4096
SECURITY_BEARER_TOKEN_MAX_LENGTH=2048
SECURITY_TENANT_HEADER_MAX_LENGTH=128
SECURITY_UI_API_KEY_MAX_LENGTH=512
SECURITY_EXPORT_DELIVERY_TIMEOUT_MS=10000
SECURITY_EXPORT_DELIVERY_MAX_RESPONSE_BYTES=32768
SECURITY_EXPORT_DELIVERY_MAX_RECORDS_PER_TENANT=100
SECURITY_EXPORT_DELIVERY_MAX_ACTIVE_PER_TENANT=10
SECURITY_EXPORT_DELIVERY_IDEMPOTENCY_TTL_SECONDS=3600
SECURITY_EXPORT_DELIVERY_IDEMPOTENCY_KEY_MAX_LENGTH=128
SECURITY_EXPORT_DELIVERY_RETRY_BASE_DELAY_MS=5000
SECURITY_EXPORT_DELIVERY_RETRY_MAX_DELAY_MS=60000
SECURITY_EXPORT_DELIVERY_MAX_ATTEMPTS=4
SECURITY_EXPORT_DELIVERY_MAX_MANUAL_REDRIVES=2
SECURITY_EXPORT_DELIVERY_POLICY_DEFAULT_MODE=inherit_remote_policy
SECURITY_EXPORT_DELIVERY_POLICY_DEFAULT_ALLOWED_TARGETS=
SECURITY_EXPORT_DELIVERY_POLICY_MAX_ALLOWED_TARGETS=32
SECURITY_EXPORT_SIGNING_MAX_VERIFY_KEYS=4
SECURITY_EXPORT_DELIVERY_ALLOWED_PORTS=443
SECURITY_EXPORT_DELIVERY_ALLOW_IP_LITERALS=false
SECURITY_EXPORT_DELIVERY_USER_AGENT=SMART-AI-Security-Delivery/1.0

# Runtime
PORT=8080
REQUEST_TIMEOUT_MS=45000
RATE_LIMIT_PER_MINUTE=60
UI_SESSION_TTL_SECONDS=1800
UI_SESSION_MAX_IDLE_SECONDS=900
UI_SESSION_MAX_AUTH_FAILURES=5
UI_SESSION_AUTH_BLOCK_SECONDS=120
UI_SESSION_MAX_SESSIONS_PER_TENANT=5
UI_SESSION_MAX_SESSIONS_GLOBAL=2000
UI_SESSION_PERSIST_DEBOUNCE_MS=250
UI_ALLOWED_ORIGINS=
MAX_STEPS=6
MAX_TOOL_CALLS=6
MAX_RUNTIME_MS=60000

# Orchestrator tuning
ORCHESTRATOR_MAX_TOOL_PASSES=4
ORCHESTRATOR_MAX_REPEATED_TOOL_PASSES=2
VERIFIER_MIN_CITATIONS=2
VERIFIER_MIN_SOURCE_DOMAINS=2
RESEARCH_MAX_QUERIES=3
RESEARCH_MAX_CONCURRENT_UNITS=2
RESEARCH_MAX_QUERY_CHARS=4000
RESEARCH_MAX_ACTIVE_JOBS_PER_TENANT=2
RESEARCH_IDEMPOTENCY_KEY_MAX_LENGTH=128
RESEARCH_IDEMPOTENCY_TTL_SECONDS=3600
RESEARCH_JOB_TIMEOUT_MS=120000
RESEARCH_MAX_JOBS_PER_TENANT=500

# Optional: per-tenant allowed tools JSON map
# TENANT_TOOL_POLICIES_JSON={"tenant-a":["web_search","wikipedia","rag_search"]}
TENANT_TOOL_POLICIES_JSON=

# Optional external tool providers
EXA_API_KEY=
FINANCIAL_DATASETS_API_KEY=
ALPHA_VANTAGE_API_KEY=
BRAVE_API_KEY=
BRAVE_API_BASE_URL=https://api.search.brave.com/res/v1/web/search

# Optional RAG config
RAG_STORE_FILE=
RAG_DEFAULT_CHUNK_SIZE=1200
RAG_DEFAULT_CHUNK_OVERLAP=180
RAG_REMOTE_FETCH_TIMEOUT_MS=15000
RAG_REMOTE_FETCH_MAX_BYTES=1000000
RAG_REMOTE_FETCH_MAX_REDIRECTS=3
RAG_REMOTE_PREVIEW_CHARS=600
RAG_REMOTE_ALLOWED_PORTS=80,443
RAG_REMOTE_ALLOWED_CONTENT_TYPES=text/html,text/plain,text/markdown,application/json,application/xml,text/xml,application/xhtml+xml
RAG_REMOTE_POLICY_DEFAULT_MODE=preview_only
RAG_REMOTE_POLICY_DEFAULT_ALLOWED_HOSTS=
RAG_REMOTE_POLICY_MAX_ALLOWED_HOSTS=32
RAG_REMOTE_USER_AGENT=SMART-AI-RAG/1.0
MODEL_POLICY_FILE=
RAG_REMOTE_POLICY_FILE=
UI_SESSION_STORE_FILE=
SECURITY_AUDIT_STORE_FILE=
SECURITY_EXPORT_DELIVERY_STORE_FILE=
SECURITY_EXPORT_DELIVERY_POLICY_FILE=
SECURITY_EXPORT_SIGNING_STORE_FILE=

# Optional Memory config
MEMORY_STORE_FILE=
MEMORY_DEFAULT_CATEGORY=note
MEMORY_MAX_ITEMS_PER_TENANT=2500
MEMORY_AUTO_CAPTURE_USER_MESSAGES=true
MEMORY_HOTNESS_HALF_LIFE_DAYS=7

# Optional QMD local-search integration (use installed VPS qmd binary)
QMD_ENABLED=true
QMD_COMMAND=qmd
QMD_TIMEOUT_MS=15000
QMD_COLLECTION_NAME=SMART-AI
QMD_COLLECTION_PATH=
QMD_COLLECTION_AUTO_ADD=true
QMD_MAX_RESULTS=6
QMD_MAX_SNIPPET_CHARS=260

# Optional Turkish domain MCP integrations (via mcporter)
MCPORTER_COMMAND=mcporter
MCPORTER_TIMEOUT_MS=45000
MCP_MAX_RESULTS=6
MEVZUAT_MCP_URL=https://mevzuat.surucu.dev/mcp
BORSA_MCP_URL=https://borsamcp.fastmcp.app/mcp
YARGI_MCP_URL=https://yargimcp.fastmcp.app/mcp
YARGI_MCP_FALLBACK_ENABLED=true

# Optional OpenBB tool integration
OPENBB_ENABLED=false
OPENBB_API_BASE_URL=http://127.0.0.1:6900
OPENBB_API_PREFIX=/api/v1
OPENBB_API_TIMEOUT_MS=12000
OPENBB_PROVIDER=yfinance
OPENBB_NEWS_PROVIDER=benzinga
OPENBB_WORLD_NEWS_PROVIDER=fmp
OPENBB_AUTH_TOKEN=
OPENBB_USERNAME=
OPENBB_PASSWORD=
OPENBB_MAX_SYMBOLS=3
OPENBB_HISTORY_LIMIT=60
OPENBB_NEWS_LIMIT=6

# Optional MCP health persistence
MCP_HEALTH_PERSIST_ENABLED=true
MCP_HEALTH_PERSIST_MODE=file
MCP_HEALTH_STORE_FILE=
MCP_HEALTH_PERSIST_HTTP_URL=
MCP_HEALTH_PERSIST_HTTP_TOKEN=
MCP_HEALTH_PERSIST_HTTP_TIMEOUT_MS=2500
MCP_HEALTH_PERSIST_DEBOUNCE_MS=750
